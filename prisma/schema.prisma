generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  BRANCH_MANAGER
}

enum ReportStatus {
  SUBMITTED
  REVIEWED
}

model Branch {
  id           String              @id @default(cuid())
  name         String              @unique
  city         String
  createdAt    DateTime            @default(now())
  users        User[]
  reports      DailyReport[]
  saleReports  SaleReport[]
  staff        Staff[]
  vehicleStock VehicleStock[]
  cashSheets   CashSheet[]
  expenses     DealershipExpense[]
}

model User {
  id           String              @id @default(cuid())
  email        String              @unique
  passwordHash String
  name         String
  role         Role
  branchId     String?
  branch       Branch?             @relation(fields: [branchId], references: [id])
  reports      DailyReport[]
  saleReports  SaleReport[]
  cashSheets   CashSheet[]
  expenses     DealershipExpense[]
  createdAt    DateTime            @default(now())
}

model DailyReport {
  id                String       @id @default(cuid())
  date              DateTime
  branchId          String
  branch            Branch       @relation(fields: [branchId], references: [id])
  submittedById     String
  submittedBy       User         @relation(fields: [submittedById], references: [id])

  vehiclesSold        Int          @default(0)
  salesValue          Float        @default(0)
  bookings            Int          @default(0)
  pendingDeliveries   Int          @default(0)
  testDrives          Int          @default(0)

  serviceJobs         Int          @default(0)
  serviceRevenue      Float        @default(0)

  cashCollected       Float        @default(0)
  pendingPayments     Float        @default(0)

  staffPresent        Int          @default(0)
  customerComplaints  Int          @default(0)

  highlights          String?
  issues              String?
  notes               String?

  status              ReportStatus @default(SUBMITTED)
  reviewedAt          DateTime?
  adminComment        String?

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([branchId, date])
}

model SaleReport {
  id                 String   @id @default(cuid())
  branchId           String
  branch             Branch   @relation(fields: [branchId], references: [id])
  submittedById      String
  submittedBy        User     @relation(fields: [submittedById], references: [id])

  customerName       String
  customerFatherName String
  customerAddress    String

  modelName          String
  modelVariant       String?

  totalAmount        Float
  downPayment        Float
  financeAmount      Float
  financer           String

  aadhaarImagePath   String?

  paymentType        String   @default("Finance")
  paymentMode        String   @default("Cash")
  cashAmount         Float    @default(0)
  bankAmount         Float    @default(0)

  vehicleStock       VehicleStock?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Staff {
  id           String              @id @default(cuid())
  name         String
  role         String              // e.g. "Sales Consultant", "Service Tech", "Security"
  salary       Float               @default(0)
  active       Boolean             @default(true)
  branchId     String
  branch       Branch              @relation(fields: [branchId], references: [id])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  
  attendance   Attendance[]
  expenses     DealershipExpense[]
  transactions CashTransaction[]
}

model Attendance {
  id        String       @id @default(cuid())
  date      DateTime
  status    String       // "PRESENT", "ABSENT", "LEAVE"
  notes     String?
  staffId   String
  staff     Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([staffId, date])
}

enum StockStatus {
  AVAILABLE
  SOLD
}

model VehicleStock {
  id            String      @id @default(cuid())
  chassisNumber String      @unique
  engineNumber  String      @unique
  modelName     String
  modelVariant  String?
  color         String?
  status        StockStatus @default(AVAILABLE)
  receivedDate  DateTime    @default(now())

  // Location
  branchId      String
  branch        Branch      @relation(fields: [branchId], references: [id])

  // Sales Link
  saleReportId  String?     @unique
  saleReport    SaleReport? @relation(fields: [saleReportId], references: [id], onDelete: SetNull)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum CashSheetStatus {
  DRAFT
  SUBMITTED
}

model CashSheet {
  id              String          @id @default(cuid())
  date            DateTime
  branchId        String
  branch          Branch          @relation(fields: [branchId], references: [id])
  submittedById   String
  submittedBy     User            @relation(fields: [submittedById], references: [id])
  openingBalance  Float           @default(0)
  closingBalance  Float           @default(0)
  status          CashSheetStatus @default(DRAFT)
  submittedAt     DateTime?
  transactions    CashTransaction[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([branchId, date])
}

model CashTransaction {
  id          String    @id @default(cuid())
  cashSheetId String
  cashSheet   CashSheet @relation(fields: [cashSheetId], references: [id], onDelete: Cascade)
  type        String    // "CREDIT" or "DEBIT"
  amount      Float
  description String
  staffId     String?
  staff       Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
}

model DealershipExpense {
  id            String    @id @default(cuid())
  date          DateTime
  title         String
  description   String?
  amount        Float
  category      String    // e.g. "Rent", "Utilities", "Marketing", "Inventory", "Salaries", "Taxes", "Other"
  recordedById  String
  recordedBy    User      @relation(fields: [recordedById], references: [id])
  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  staffId       String?
  staff         Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
